---
// src/pages/admin/index.astro
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

// 导入拆分后的组件
import Sidebar from "../../components/admin/Sidebar.astro";
import DashboardView from "../../components/admin/DashboardView.astro";
import PostsView from "../../components/admin/PostsView.astro";
import DiariesView from "../../components/admin/DiariesView.astro";
import AlbumsView from "../../components/admin/AlbumsView.astro";
import SettingsView from "../../components/admin/SettingsView.astro"; // 新增配置页
---

<Layout title="Mizuki Admin - 后台管理">
    <div class="flex h-screen bg-[#f4f7f6] dark:bg-[#1a1b1e] overflow-hidden">
        <aside class="w-64 bg-white dark:bg-[#25262b] shadow-xl z-30 hidden md:flex flex-col">
            <div class="p-6 border-b border-gray-100 dark:border-gray-800">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-[var(--primary)] rounded-lg flex items-center justify-center text-white">
                        <Icon name="material-symbols:admin-panel-settings" class="text-xl" />
                    </div>
                    <span class="font-bold text-xl tracking-tight">管理后台</span>
                </div>
            </div>
            
            <nav class="flex-1 overflow-y-auto p-4 space-y-2">
                <div class="text-xs font-semibold text-gray-400 uppercase px-3 mb-2">内容管理</div>
                <button class="nav-item active" data-tab="dashboard">
                    <Icon name="material-symbols:dashboard-outline" /> 控制台
                </button>
                <button class="nav-item" data-tab="posts">
                    <Icon name="material-symbols:article-outline" /> 文章管理
                </button>
                <button class="nav-item" data-tab="diaries">
                    <Icon name="material-symbols:book-outline" /> 日记/碎碎念
                </button>
                <button class="nav-item" data-tab="albums">
                    <Icon name="material-symbols:photo-library" /> 相册媒体
                </button>

                <div class="text-xs font-semibold text-gray-400 uppercase px-3 mt-6 mb-2">系统设置</div>
                <button class="nav-item" data-tab="config">
                    <Icon name="material-symbols:settings-outline" /> 站点配置 (Config)
                </button>
                <button class="nav-item" data-tab="nav">
                    <Icon name="material-symbols:menu-open" /> 导航菜单定制
                </button>
            </nav>

            <div class="p-4 border-t border-gray-100 dark:border-gray-800">
                <a href="/" data-no-swup class="flex items-center gap-2 text-sm text-gray-500 hover:text-[var(--primary)] transition">
                    <Icon name="material-symbols:arrow-back" /> 返回前台
                </a>
                <button id="logout-btn" class="flex items-center gap-2 text-sm text-red-400 hover:text-red-500 transition mt-4">
                    <Icon name="material-symbols:logout-rounded" /> 退出登录
                </button>
            </div>
        </aside>

        <main class="flex-1 flex flex-col min-w-0 overflow-hidden relative z-10">
            <header class="h-16 bg-white dark:bg-[#25262b] shadow-sm flex items-center justify-between px-8">
                <h2 id="current-tab-title" class="text-lg font-bold text-gray-700 dark:text-gray-200">控制台</h2>
                <div class="flex items-center gap-4">
                    <button id="rebuild-btn" class="flex items-center gap-2 px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg text-sm transition">
                        <Icon name="material-symbols:refresh" /> 触发重构 (Build)
                    </button>
                </div>
            </header>

            <section id="admin-main-view" class="flex-1 p-8 overflow-y-auto">
                <div id="dashboard-view" class="tab-content">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                        <div class="stat-card">
                            <span class="text-gray-500 text-sm">文章总数</span>
                            <div class="text-3xl font-bold mt-1" id="stat-posts">-</div>
                        </div>
                        <div class="stat-card">
                            <span class="text-gray-500 text-sm">分类数量</span>
                            <div class="text-3xl font-bold mt-1" id="stat-categories">-</div>
                        </div>
                        <div class="stat-card">
                            <span class="text-gray-500 text-sm">运行天数</span>
                            <div class="text-3xl font-bold mt-1" id="stat-days">-</div>
                        </div>
                        <div class="stat-card">
                            <span class="text-gray-500 text-sm">总字数</span>
                            <div class="text-3xl font-bold mt-1" id="stat-words">-</div>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-[#25262b] rounded-xl p-6 shadow-sm">
                        <h3 class="font-bold mb-4">快捷操作</h3>
                        <div class="flex gap-4">
                            <a href="/admin/new-post/" data-no-swup class="quick-btn bg-blue-50 text-blue-600">写新文章</a>
                            <button class="quick-btn bg-purple-50 text-purple-600">发布日记</button>
                            <button class="quick-btn bg-orange-50 text-orange-600">上传相片</button>
                        </div>
                    </div>
                </div>

                <div id="posts-view" class="tab-content hidden">
                    <div class="flex justify-between mb-4">
                        <input type="text" placeholder="搜索文章标题..." class="px-4 py-2 rounded-lg border dark:bg-gray-800" />
                        <a href="/admin/new-post/" class="bg-[var(--primary)] text-white px-4 py-2 rounded-lg">+ 新增文章</a>
                    </div>
                    <div class="bg-white dark:bg-[#25262b] rounded-xl shadow-sm overflow-hidden">
                        <table class="w-full text-left">
                            <thead class="bg-gray-50 dark:bg-gray-800 text-gray-500 text-sm">
                                <tr>
                                    <th class="p-4">标题</th>
                                    <th class="p-4">分类</th>
                                    <th class="p-4">日期</th>
                                    <th class="p-4 text-right">操作</th>
                                </tr>
                            </thead>
                            <tbody id="posts-list-table">
                                </tbody>
                        </table>
                    </div>
                </div>
                <div id="diaries-view" class="tab-content hidden">
                    <div class="flex justify-between mb-6">
                        <h3 class="text-xl font-bold dark:text-gray-100">日记/碎碎念管理</h3>
                        <button id="add-diary-btn" class="bg-purple-600 text-white px-6 py-2 rounded-xl font-bold hover:bg-purple-700 transition shadow-lg shadow-purple-500/20">
                            + 发布新动态
                        </button>
                    </div>
                    <div id="diary-form-container" class="mb-8 bg-white dark:bg-[#25262b] p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 hidden">
                        <textarea id="diary-content" rows="4" placeholder="今天想说点什么..." class="w-full p-4 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-purple-500 transition-all"></textarea>
                        <div id="diary-image-preview" class="flex flex-wrap gap-2 mt-2"></div>

                        <div class="mt-4 flex flex-wrap gap-4 items-center">
                            <button id="diary-upload-trigger" type="button" class="flex items-center gap-2 px-4 py-2 border rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm">
                                <Icon name="material-symbols:add-photo-alternate-outline" /> 上传图片
                            </button>
                            <input type="file" id="diary-file-input" class="hidden" multiple accept="image/*" />
                        </div>
                    
                        <div class="mt-4 flex flex-wrap gap-4 items-center">
                            <input type="text" id="diary-location" placeholder="地点 (可选)" class="px-4 py-2 rounded-lg border dark:bg-gray-800 dark:border-gray-700 text-sm" />
                            <input type="text" id="diary-mood" placeholder="心情 (可选)" class="px-4 py-2 rounded-lg border dark:bg-gray-800 dark:border-gray-700 text-sm" />
                            <div class="flex-1"></div>
                            <button id="cancel-diary-btn" class="px-6 py-2 text-gray-500">取消</button>
                            <button id="submit-diary-btn" class="bg-purple-600 text-white px-8 py-2 rounded-xl font-bold">立即发布</button>
                        </div>
                    </div>
                    <div id="diary-list-container" class="space-y-4">
                    </div>
                </div>
                <div id="albums-view" class="tab-content hidden">
                    <div class="flex justify-between mb-6">
                        <h3 class="text-xl font-bold dark:text-gray-100 text-slate-800">相册媒体管理</h3>
                        <button id="new-album-btn" class="bg-orange-500 text-white px-6 py-2 rounded-xl font-bold hover:bg-orange-600 transition shadow-lg">
                            + 新建相册
                        </button>
                    </div>

                    <div id="albums-list" class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
                    </div>
                </div>

                <dialog id="album-dialog" class="rounded-2xl p-6 bg-white dark:bg-[#25262b] shadow-2xl border-none w-full max-w-lg">
                    <h3 class="text-xl font-bold mb-6 text-slate-800 dark:text-gray-100 flex items-center gap-2">
                        <span class="w-2 h-6 bg-orange-500 rounded-full"></span>
                        创建新相册
                    </h3>
    
                    <div class="space-y-4 max-h-[70vh] overflow-y-auto px-1">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">相册 ID (文件夹名)</label>
                                <input type="text" id="album-id" placeholder="e.g. travel-2024" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-orange-500 transition" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">相册标题</label>
                                <input type="text" id="album-title" placeholder="显示在页面的名称" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-orange-500 transition" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">相册描述</label>
                            <textarea id="album-desc" placeholder="简短介绍这个相册..." rows="2" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-orange-500 transition"></textarea>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">日期</label>
                                <input type="date" id="album-date" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-orange-500 transition" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">拍摄地点</label>
                                <input type="text" id="album-location" placeholder="e.g. 日本, 东京" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-orange-500 transition" />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">布局方式</label>
                                <select id="album-layout" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none">
                                    <option value="masonry">瀑布流 (Masonry)</option>
                                    <option value="grid">网格 (Grid)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">列数 (2-4)</label>
                                <input type="number" id="album-columns" value="3" min="2" max="4" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-400 mb-1 uppercase">标签 (逗号分隔)</label>
                            <input type="text" id="album-tags" placeholder="旅行, 生活, 摄影" class="w-full p-3 rounded-xl border dark:bg-gray-800 dark:border-gray-700 outline-none focus:border-orange-500 transition" />
                        </div>

                        <div class="flex items-center gap-2 pt-2">
                            <input type="checkbox" id="album-hidden" class="w-4 h-4 accent-orange-500" />
                            <label for="album-hidden" class="text-sm font-medium text-gray-600 dark:text-gray-400">不在列表页公开显示 (隐藏相册)</label>
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 mt-8">
                        <button onclick="document.getElementById('album-dialog').close()" class="px-6 py-2 text-gray-500 hover:text-gray-700 transition font-medium">取消</button>
                        <button id="confirm-create-album" class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-2 rounded-xl font-bold shadow-lg shadow-orange-500/20 active:scale-95 transition">
                            创建相册
                        </button>
                    </div>
                </dialog>
                <dialog id="photo-manager-dialog" class="rounded-2xl p-6 bg-white dark:bg-[#25262b] shadow-2xl border-none w-full max-w-3xl">
                    <div class="flex justify-between items-center mb-4">
                        <h3 id="mgr-album-title" class="text-xl font-bold">管理相册图片</h3>
                        <button onclick="document.getElementById('photo-manager-dialog').close()" class="text-gray-400">关闭</button>
                    </div>
    
                    <div class="space-y-4">
                        <div class="p-8 border-2 border-dashed border-gray-100 dark:border-gray-800 rounded-2xl text-center">
                            <input type="file" id="photo-upload-input" class="hidden" multiple accept="image/*" />
                            <p class="text-sm text-gray-500 mb-4">图片将直接保存至 public/images/albums/<span id="mgr-album-id"></span>/</p>
                            <button onclick="document.getElementById('photo-upload-input').click()" class="bg-blue-600 text-white px-6 py-2 rounded-xl font-bold">上传照片</button>
                        </div>

                        <div id="mgr-photos-grid" class="grid grid-cols-4 gap-4 max-h-96 overflow-y-auto p-2">
                            </div>
                    </div>
                </dialog>
            </section>
        </main>
    </div>
</Layout>

<style>
    .nav-item {
        @apply flex items-center gap-3 w-full px-4 py-3 text-left rounded-xl transition-all text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800;
    }
    .nav-item.active {
        @apply bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-bold;
    }
    .stat-card {
        @apply bg-white dark:bg-[#25262b] p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800;
    }
    .quick-btn {
        @apply px-6 py-4 rounded-xl font-bold transition active:scale-95;
    }
    .nav-item {
        @apply flex items-center gap-3 w-full px-4 py-3 text-left rounded-xl transition-all text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800;
    }
    .nav-item.active {
        @apply bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-bold;
    }
    .stat-card {
        @apply bg-white dark:bg-[#25262b] p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800;
    }
    .quick-btn {
        @apply px-6 py-4 rounded-xl font-bold transition active:scale-95 text-sm;
    }

    /* 修复报错：手动定义动画代替 tailwind-animate 插件 */
    .tab-content {
        animation: slideIn 0.3s ease-out forwards;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    // 封装认证请求
    async function authFetch(url, options: any = {}) {
        const token = localStorage.getItem('mizuki_token');
        if (!token) {
            window.location.href = '/admin/login/';
            return;
        }
        const headers = {
            ...options.headers,
            'Authorization': `Bearer ${token}`
        };
        
        const response = await fetch(url, { ...options, headers });
        
        // 如果后端返回 401，说明 Token 失效了，直接踢回登录页
        if (response.status === 401) {
            localStorage.removeItem('mizuki_token');
            window.location.href = '/admin/login/';
            throw new Error("Unauthorized");
        }
        
        return response;
    }
    async function refreshStats() {
        try {
            const res = await authFetch('http://localhost:8080/api/admin/stats');
            const data = await res.json();

            // 精准填入对应的 ID [cite: 99, 100, 101, 102]
            const statPosts = document.getElementById('stat-posts');
            const statCategories = document.getElementById('stat-categories');
            const statDays = document.getElementById('stat-days');
            const statWords = document.getElementById('stat-words');

            if (statPosts) statPosts.innerText = data.postCount;
            if (statCategories) statCategories.innerText = data.categoryCount;
            if (statDays) statDays.innerText = data.runningDays;
            if (statWords) {
                // 如果字数过万，进行友好格式化
                statWords.innerText = data.totalWords > 10000 
                    ? (data.totalWords / 1000).toFixed(1) + 'k' 
                    : data.totalWords;
            }
        } catch (e) {
            console.error("统计数据加载失败");
        }
    }
    const token = localStorage.getItem('mizuki_token')
    if (!token) {
        //如果没有token踢回登录页
        window.location.href = '/admin/login/'
    }
    // --- 1. 侧边栏 Tab 切换逻辑 (补全) ---
    const navItems = document.querySelectorAll('.nav-item');
    const tabContents = document.querySelectorAll('.tab-content');
    const titleHeader = document.getElementById('current-tab-title');

    navItems.forEach(item => {
        item.addEventListener('click', () => {
            const tabId = item.getAttribute('data-tab');
            navItems.forEach(nav => nav.classList.remove('active'));
            item.classList.add('active');

            // 切换视图内容
            tabContents.forEach(content => content.classList.add('hidden'));
            const targetView = document.getElementById(`${tabId}-view`);
            if (targetView) targetView.classList.remove('hidden');

            // 更新标题
            if (titleHeader) titleHeader.innerText = (item as HTMLElement).innerText.trim();
            
            // 如果切换到文章管理，自动刷新列表
            if (tabId === 'posts') refreshPostList();
            if (tabId === 'diaries') refreshDiaryList();
            if (tabId === 'dashboard') refreshStats();
            if (tabId === 'albums') refreshAlbumList();
        });
    });
    

    // --- 2. 渲染文章列表 (适配 Go 结构体首字母大写) ---
    async function refreshPostList() {
        const tableBody = document.getElementById('posts-list-table');
        if (!tableBody) return;

        try {
            const res = await authFetch('http://localhost:8080/api/admin/posts',{
                header:{
                    'Authorization': `Bearer ${localStorage.getItem('mizuki_token')}`
                }
            });
            if (res.status === 401) {
                alert("登陆已过期，请重新登录");
                window.location.href = '/admin/login/';
                return;
            }
            const posts = await res.json();

            // 注意：此处 post.Title, post.Category, post.Slug 必须首字母大写
            tableBody.innerHTML = posts.map(post => `
                <tr class="border-b dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
                    <td class="p-4 font-medium">${post.Title || post.title}</td>
                    <td class="p-4">
                        <span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded text-xs text-gray-600 dark:text-gray-300">
                            ${post.Category || post.category || '未分类'}
                        </span>
                    </td>
                    <td class="p-4 text-sm text-gray-500">
                        ${new Date(post.CreatedAt || post.created_at).toLocaleDateString()}
                    </td>
                    <td class="p-4 text-right">
                        <button onclick="location.href='/admin/edit-post/?slug=${post.Slug || post.slug}'" 
                            class="text-blue-500 hover:text-blue-600 font-medium px-2">修改</button>
                        <button onclick="window.handleDelete('${post.Slug || post.slug}')" 
                                class="text-red-500 hover:text-red-600 font-medium px-2">删除</button>
                    </td>
                </tr>
            `).join('');
            
            const postStat = document.getElementById('stat-posts');
            if(postStat) postStat.innerText = posts.length;
        } catch (e) {
            tableBody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-red-400">无法连接后端，请检查 Go 服务是否启动</td></tr>';
        }
    }

    // --- 3. 删除逻辑 ---
    (window as any).handleDelete = async (slug: string) => {
        if(!confirm(`确定要彻底删除文章 [${slug}] 吗？\n这将同时删除数据库记录和磁盘文件！`)) return;
        try {
            const res = await authFetch(`http://localhost:8080/api/admin/posts/${slug}`, { method: 'DELETE' });
            if(res.ok) {
                alert("物理同步删除成功");
                refreshPostList();
            } else {
                const err = await res.json();
                alert("删除失败：" + (err.error || "未知错误"));
            }
        } catch(e) {
            alert("请求失败");
        }
    };
    // 日记管理逻辑
    const diaryForm = document.getElementById('diary-form-container');
    const diaryList = document.getElementById('diary-list-container');

    // 切换发布框显示
    document.getElementById('add-diary-btn')?.addEventListener('click', () => {
        diaryForm?.classList.toggle('hidden');
    });
    // 1. 定义统一的重置函数
    function resetDiaryForm() {
        // 清空文本和输入框
        (document.getElementById('diary-content') as HTMLTextAreaElement).value = "";
        (document.getElementById('diary-location') as HTMLInputElement).value = "";
        (document.getElementById('diary-mood') as HTMLInputElement).value = "";
    
        // 清空图片状态数据
        diaryUploadedImages = [];
    
        // 清空预览区 DOM
        const previewContainer = document.getElementById('diary-image-preview');
        if (previewContainer) previewContainer.innerHTML = "";
    
        // 隐藏表单
        const diaryForm = document.getElementById('diary-form-container');
        diaryForm?.classList.add('hidden');
    }
    //取消按钮
    document.getElementById('cancel-diary-btn')?.addEventListener('click', () => {
        if (diaryUploadedImages.length > 0) {
            if (!confirm("已上传的图片将不会被保存，确定取消吗？")) return;
        }
        resetDiaryForm();
    });

    // 获取日记列表 (解析自后端读取的 diary.ts)
    async function refreshDiaryList() {
        if (!diaryList) return;
        try {
            const res = await authFetch('http://localhost:8080/api/admin/diaries');
            const diaries = await res.json();
            
            diaryList.innerHTML = diaries.map(item => `
                <div class="bg-white dark:bg-[#25262b] p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-xs text-gray-400 font-mono">${new Date(item.date).toLocaleString()}</span>
                        <div class="flex gap-2">
                            <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-800 rounded text-gray-500">${item.mood || '😶'}</span>
                            <button onclick="window.deleteDiary(${item.id})" class="text-red-400 hover:text-red-500 text-xs">删除</button>
                        </div>
                    </div>
                    <p class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap">${item.content}</p>
                    ${item.location ? `<div class="mt-3 text-xs text-blue-400 flex items-center gap-1">📍 ${item.location}</div>` : ''}
                </div>
            `).join('');
        } catch (e) {
            diaryList.innerHTML = '<p class="text-center text-red-400">加载日记失败</p>';
        }
    }

    let diaryUploadedImages = []; // 存储上传成功的图片路径

    // 触发文件选择
    document.getElementById('diary-upload-trigger')?.addEventListener('click', () => {
        document.getElementById('diary-file-input').click();
    });

    // 处理文件上传
    document.getElementById('diary-file-input')?.addEventListener('change', async (e) => {
        const files = e.target.files;
        const previewContainer = document.getElementById('diary-image-preview');
    
        for (const file of files) {
            const formData = new FormData();
            formData.append('file', file);
            formData.append('slug', 'diary'); // 日记图片可以统一放在 diary 目录下

            try {
                // 复用文章上传接口
                const res = await authFetch('http://localhost:8080/api/admin/upload', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();

                if (data.code === 0) {
                    const url = Object.values(data.data.succMap)[0];
                    // 增加时间戳后缀防止 404 缓存
                    const freshUrl = `${url}?t=${Date.now()}`; 
                    diaryUploadedImages.push(url); // 存入数据库的路径不需要后缀
    
                    const img = document.createElement('img');
                    img.src = freshUrl; // 预览使用带后缀的 URL
                    img.className = "w-20 h-20 object-cover rounded-lg border dark:border-gray-700";
                    previewContainer.appendChild(img);
                }
            } catch (err) {
                console.error("图片上传失败", err);
            }
        }
    });

    // 提交新日记
    document.getElementById('submit-diary-btn')?.addEventListener('click', async () => {
        const content = (document.getElementById('diary-content') as HTMLTextAreaElement).value;
        const location = (document.getElementById('diary-location') as HTMLInputElement).value;
        const mood = (document.getElementById('diary-mood') as HTMLInputElement).value;

        if (!content) return alert("内容不能为空");

        try {
            const res = await authFetch('http://localhost:8080/api/admin/diaries', {
                method: 'POST',
                body: JSON.stringify({ content, location, mood, images: diaryUploadedImages })
            });

            if (res.ok) {
                diaryUploadedImages = [];
                document.getElementById('diary-image-preview').innerHTML = "";
                (document.getElementById('diary-content') as HTMLTextAreaElement).value = "";
                diaryForm?.classList.add('hidden');
                refreshDiaryList();
                alert("动态发布成功！请手动触发重构以更新前台。");
            }
        } catch (e) {
            alert("发布失败");
        }
    });

    // 删除日记 (暴露给全局 window)
    (window as any).deleteDiary = async (id: number) => {
        if (!confirm("确定删除这条日记吗？")) return;
        // 注意：后端需要对应实现 DELETE /api/admin/diaries/:id
        try {
            const res = await authFetch(`http://localhost:8080/api/admin/diaries/${id}`, { method: 'DELETE' });
            if (res.ok) refreshDiaryList();
        } catch (e) {
            alert("删除失败");
        }
    };

    async function refreshAlbumList() {
        console.log("Starting to render album list...");
        const listContainer = document.getElementById('albums-list');
        if (!listContainer) {
            console.error("Target container #albums-list not found!");
            return;
        }

        try {
            const res = await authFetch('http://localhost:8080/api/admin/albums');
            const albums = await res.json();
            console.log("Albums data:", albums);

            listContainer.innerHTML = albums.map(album => `
                <div class="bg-white dark:bg-[#25262b] rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden group">
                    <div class="aspect-[4/3] bg-gray-100 relative overflow-hidden">
                        <img src="${album.cover}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                            onerror="if(!this.dataset.tried){this.dataset.tried=1;this.src='/images/logo.png';}else{this.style.display='none';}" />
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-4">
                            <button onclick="window.managePhotos('${album.id}')" 
                                    class="px-3 py-1 bg-white rounded-full text-orange-500 text-xs font-bold hover:scale-110 transition">
                                管理
                            </button>
                            <button onclick="window.deleteAlbum('${album.id}')" 
                                    class="px-3 py-1 bg-white rounded-full text-red-500 text-xs font-bold hover:scale-110 transition">
                                删除
                            </button>
                        </div>
                    </div>
                    <div class="p-4">
                        <h4 class="font-bold text-slate-800 dark:text-gray-100 truncate">${album.info.title || album.id}</h4>
                        <p class="text-xs text-slate-400 mt-1">${album.info.date || '未设置日期'}</p>
                    </div>
                </div>
            `).join('');
        } catch (e) {
            console.error("加载相册失败");
        }
    }

    // 删除相册逻辑
    (window as any).deleteAlbum = async (id: string) => {
        if (!confirm(`确定要物理删除相册 [${id}] 吗？此操作不可恢复！`)) return;
        try {
            const res = await authFetch(`http://localhost:8080/api/admin/albums/${id}`, { method: 'DELETE' });
            if (res.ok) refreshAlbumList();
        } catch (e) { alert("删除失败"); }
    };

    (window as any).managePhotos = (albumID: string) => {
        console.log("正在打开相册管理面板，ID:", albumID);
    
        // 1. 获取弹窗元素
        const dialog = document.getElementById('photo-manager-dialog') as any;
        const mgrIdLabel = document.getElementById('mgr-album-id');
    
        if (!dialog || !mgrIdLabel) {
            console.error("找不到相册管理弹窗元素");
            return;
        }

        // 2. 设置当前操作的相册 ID 到 UI
        mgrIdLabel.innerText = albumID;
    
        // 3. 唤起原生弹窗
        dialog.showModal();
    
        // 4. 加载该相册下的文件列表
        refreshPhotoGrid(albumID);
    };

    const albumDialog = document.getElementById('album-dialog');
    const newAlbumBtn = document.getElementById('new-album-btn');

    // 2. 绑定点击事件以显示弹窗
    if (newAlbumBtn && albumDialog) {
        newAlbumBtn.addEventListener('click', () => {
            // 使用 showModal() 可以显示带背景遮罩的原生弹窗 
            (albumDialog as any).showModal(); 
        });
    }

    // 绑定“新建相册”提交
    document.getElementById('confirm-create-album')?.addEventListener('click', async () => {
        const id = (document.getElementById('album-id') as HTMLInputElement).value.trim();
        const title = (document.getElementById('album-title') as HTMLInputElement).value.trim();
    
        if (!id || !title) return alert("相册 ID 和标题是必填项");

        const payload = {
            id: id,
            info: {
                title: title,
                description: (document.getElementById('album-desc') as HTMLTextAreaElement).value.trim(),
                date: (document.getElementById('album-date') as HTMLInputElement).value || new Date().toISOString().split('T')[0],
                location: (document.getElementById('album-location') as HTMLInputElement).value.trim(),
                tags: (document.getElementById('album-tags') as HTMLInputElement).value
                    .split(',')
                    .map(t => t.trim())
                    .filter(Boolean),
                layout: (document.getElementById('album-layout') as HTMLSelectElement).value,
                columns: parseInt((document.getElementById('album-columns') as HTMLInputElement).value) || 3,
                hidden: (document.getElementById('album-hidden') as HTMLInputElement).checked,
                mode: "local" // 默认为本地扫描模式
            }
        };

        try {
            const res = await authFetch('http://localhost:8080/api/admin/albums', {
                method: 'POST',
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                alert("相册配置已生成！");
                (document.getElementById('album-dialog') as any).close();
            
                // 清空表单
                const fields = ['album-id', 'album-title', 'album-desc', 'album-location', 'album-tags'];
                fields.forEach(f => (document.getElementById(f) as any).value = "");
                refreshAlbumList(); // 重新加载列表
            }
        } catch (e) {
            alert("创建失败，请检查后端终端报错");
        }
    });

    // 挂载到 window 供列表调用
    (window as any).openPhotoManager = async (albumID: string) => {
        document.getElementById('mgr-album-id').innerText = albumID;
        const dialog = document.getElementById('photo-manager-dialog') as any;
        dialog.showModal();
    
        // 加载当前相册的图片列表
        refreshPhotoGrid(albumID);
    };

    // 刷新图片网格（需要后端增加一个获取单相册文件列表的接口，或通过 AlbumListItem 获取）
    async function refreshPhotoGrid(albumID) {
        const grid = document.getElementById('mgr-photos-grid');
        if (!grid) return;
    
        try {
            const res = await authFetch(`http://localhost:8080/api/admin/albums/${albumID}/files`);
            
            if (res.ok) {
                const files = await res.json();
                if (files.length === 0) {
                    grid.innerHTML = '<p class="col-span-4 text-center text-gray-400">暂无图片，请上传</p>';
                } else {
                    grid.innerHTML = files.map(file => `
                        <div class="relative group aspect-square rounded-xl overflow-hidden border dark:border-gray-800 bg-gray-50">
                            <img src="/images/albums/${albumID}/${file}?t=${Date.now()}" class="w-full h-full object-cover" />
                            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-2">
                                ${file === 'cover.jpg' ? 
                                    '<span class="bg-orange-500 text-white text-[10px] px-2 py-1 rounded-full">当前封面</span>' : 
                                    `<button onclick="window.setAsCover('${albumID}', '${file}')" class="bg-white text-black text-[10px] px-2 py-1 rounded-full hover:bg-orange-500 hover:text-white transition">设为封面</button>`
                                }
                                <button onclick="window.deletePhoto('${albumID}', '${file}')" class="bg-red-500 text-white text-[10px] px-2 py-1 rounded-full">删除图片</button>
                            </div>
                        </div>
                    `).join('');
                }
            } else {
                grid.innerHTML = '<p class="col-span-4 text-center text-red-400">加载失败</p>';
            }            
        } catch (e) {
            grid.innerHTML = '<p class="col-span-full text-center text-red-400">读取文件失败</p>';
        }
    }

    (window as any).setAsCover = async (albumID, filename) => {
        const res = await authFetch(`http://localhost:8080/api/admin/albums/${albumID}/set-cover`, {
            method: 'POST',
            body: JSON.stringify({ filename })
        });
        if (res.ok) {
            refreshPhotoGrid(albumID);
            refreshAlbumList(); // 列表页封面同步更新
        }
    };

    (window as any).deletePhoto = async (albumID, filename) => {
        if (!confirm(`确定删除图片 ${filename} 吗？`)) return;
        const res = await authFetch(`http://localhost:8080/api/admin/albums/${albumID}/files/${filename}`, {
            method: 'DELETE'
        });
        if (res.ok) refreshPhotoGrid(albumID);
    };

    // 处理图片上传
    document.getElementById('photo-upload-input')?.addEventListener('change', async (e) => {
        const files = e.target.files;
        const albumID = document.getElementById('mgr-album-id').innerText;
        if (!files || files.length === 0) return;

        for (const f of files) {
            const formData = new FormData();
            formData.append('file', f); 
            formData.append('slug', `albums/${albumID}`);
            try {
                const res = await authFetch('http://localhost:8080/api/admin/upload', {
                    method: 'POST',
                    body: formData
                });
                if (res.ok) console.log(`文件 ${f.name} 上传成功`);
            } catch (err) {
                console.error("上传失败", err);
            }
        }
        alert("上传成功！由于 Astro 静态资源限制，新图片可能需要 Rebuild 后在预览中可见。");
        refreshPhotoGrid(albumID);
        refreshAlbumList();
    });

    // --- 3. 初始执行 ---
    // 根据当前选中的 Tab 初始化
    const activeTab = document.querySelector('.nav-item.active')?.getAttribute('data-tab');
    if (activeTab === 'posts') {
        refreshPostList();
    } else if (activeTab === 'diaries') {
        refreshDiaryList();
    } else if (activeTab === 'dashboard') {
        /* 初始化控制台数据 */
        refreshStats();
    } else if (activeTab === 'albums') {
        refreshAlbumList();
        // 强制显示容器
        document.getElementById('albums-view')?.classList.remove('hidden');
    }
    

    // --- 4. 重构逻辑 ---
    const rebuildBtn = document.getElementById('rebuild-btn');
    if (rebuildBtn) {
        rebuildBtn.addEventListener('click', async () => {
            const originalText = rebuildBtn.innerHTML;
            
            // UI 反馈：改为加载状态
            rebuildBtn.disabled = true;
            rebuildBtn.innerHTML = `<span>构建中...</span>`;
            rebuildBtn.classList.replace('bg-green-500', 'bg-gray-500');

            try {
                const res = await authFetch('http://localhost:8080/api/admin/rebuild', { 
                    method: 'POST' 
                });
                
                if (res.ok) {
                    alert("项目重构成功！新静态内容已同步。");
                } else {
                    const err = await res.json();
                    alert("重构失败: " + err.error);
                }
            } catch (e) {
                alert("无法连接服务器");
            } finally {
                // 恢复按钮状态
                rebuildBtn.disabled = false;
                rebuildBtn.innerHTML = originalText;
                rebuildBtn.classList.replace('bg-gray-500', 'bg-green-500');
            }
        });
    }
    //退出登录按钮
    document.getElementById('logout-btn')?.addEventListener('click', () => {
        if(confirm('确定要退出管理系统吗？')) {
            localStorage.removeItem('mizuki_token');
            localStorage.removeItem('mizuki_user');
            window.location.href = '/admin/login/';
        }
    });
</script>