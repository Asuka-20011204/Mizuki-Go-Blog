---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

// 1. 在这里定义你的网站 Logo 路径（建议放在 /public/images/logo.png）
const websiteLogo = "/images/logo.png"; 

// 2. 在这里定义你的二次元背景图路径（建议放置一张半透明或经过淡化处理的图片，防止干扰视线）
const bgImage = "/images/login-bg.webp"; 
---

<Layout title="管理员登录 - Mizuki">
  <div id="login-page" class="min-h-screen flex items-center justify-center p-4 relative bg-cover bg-center bg-no-repeat" 
       style={`background-image: url(${bgImage});`}>
    
    <div class="absolute inset-0 bg-white/20 dark:bg-black/40 backdrop-blur-[2px]"></div>

    <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-[var(--primary)] opacity-[0.08] blur-[120px] rounded-full"></div>
      <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-blue-500 opacity-[0.08] blur-[120px] rounded-full"></div>
    </div>

    <main class="w-full max-w-md relative z-10">
      <div class="bg-white/60 dark:bg-[#25262b]/60 backdrop-blur-2xl p-8 rounded-[2rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] border border-white/20 dark:border-gray-800">
        
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 tracking-tight">管理员验证</h1>
          <p class="text-sm text-gray-500 mt-2 opacity-80">请输入凭据以访问控制台</p>
        </div>

        <form id="login-form" class="space-y-5">
          <div>
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2.5 ml-1">身份凭证 (用户名/QQ/手机)</label>
            <div class="relative">
              <Icon name="material-symbols:person-outline" class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl" />
              <input type="text" id="account" required
                class="w-full pl-12 pr-4 py-4 bg-white/40 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700 focus:border-[var(--primary)] focus:bg-white/80 dark:focus:bg-gray-700/80 rounded-2xl outline-none transition-all dark:text-gray-200"
                placeholder="输入您的账号" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2.5 ml-1">安全密码</label>
            <div class="relative">
              <Icon name="material-symbols:key-outline" class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl" />
              <input type="password" id="password" required
                class="w-full pl-12 pr-4 py-4 bg-white/40 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700 focus:border-[var(--primary)] focus:bg-white/80 dark:focus:bg-gray-700/80 rounded-2xl outline-none transition-all dark:text-gray-200"
                placeholder="••••••••" />
            </div>
          </div>

          <button type="submit" id="submit-btn"
            class="w-full py-4.5 bg-[var(--primary)] text-white rounded-2xl font-bold shadow-lg shadow-[var(--primary)]/30 hover:shadow-[var(--primary)]/50 hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
            <span>授权并进入</span>
            <Icon name="material-symbols:arrow-forward-rounded" class="text-xl" />
          </button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100/50 dark:border-gray-800/50 text-center">
            <a href="/" data-no-swup class="text-sm text-gray-400 hover:text-[var(--primary)] transition flex items-center justify-center gap-1.5">
                <Icon name="material-symbols:arrow-back-rounded" /> 返回主页
            </a>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
    /* 适配 Mizuki 的 CSS 变量和圆角 */
    :root {
        --primary: #f06292; 
    }
    #login-page {
        background-color: #1a1b1e; /* 兜底色 */
    }
    
    /* 针对输入框的 focus 状态增加轻微的光晕效果 */
    input:focus {
        box-shadow: 0 0 15px -3px var(--primary);
    }
    
    /* 增加一个简单的转场动画 */
    main {
        animation: cardIn 0.5s ease-out;
    }
    
    @keyframes cardIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
  // ... 保持原有客户端 JS 逻辑完全不变 ...
  const loginForm = document.getElementById('login-form');
  const submitBtn = document.getElementById('submit-btn');

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const account = (document.getElementById('account') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    submitBtn.disabled = true;
    submitBtn.innerHTML = `<span>验证中...</span>`;
    try {
      const response = await fetch('http://localhost:8080/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ account, password })
      });
      const data = await response.json();
      if (response.ok) {
        localStorage.setItem('mizuki_token', data.token);
        localStorage.setItem('mizuki_user', JSON.stringify(data.user));
        window.location.href = '/admin/';
      } else {
        alert(data.error || "登录失败");
      }
    } catch (err) {
      alert("无法连接服务");
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `<span>进入后台</span>`;
    }
  });
</script>