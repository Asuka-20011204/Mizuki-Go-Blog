---
// src/pages/admin/index.astro
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

// 导入拆分后的组件
import Sidebar from "../../components/admin/Sidebar.astro";
import DashboardView from "../../components/admin/DashboardView.astro";
import PostsView from "../../components/admin/PostsView.astro";
import DiariesView from "../../components/admin/DiariesView.astro";
import AlbumsView from "../../components/admin/AlbumsView.astro";
import SettingsView from "../../components/admin/SettingsView.astro"; // 新增配置页
---

<Layout title="Mizuki Admin - 后台管理">
    <div class="flex h-screen bg-[#f4f7f6] dark:bg-[#1a1b1e] overflow-hidden">
        <Sidebar />

        <main class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <header class="bg-white dark:bg-[#25262b] shadow-sm z-20 px-8 py-4 flex items-center justify-between">
                <h2 id="current-tab-title" class="text-xl font-bold text-gray-800 dark:text-white">控制台</h2>
                <div class="flex items-center gap-4">
                    <button id="rebuild-btn" class="flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all shadow-md">
                        <Icon name="material-symbols:build-circle-outline" />
                        <span>触发重构</span>
                    </button>
                    <button id="logout-btn" class="p-2 text-gray-500 hover:text-red-500 transition-colors" title="退出登录">
                        <Icon name="material-symbols:logout" class="text-xl" />
                    </button>
                </div>
            </header>

            <div id="admin-main-view" class="flex-1 p-8 overflow-y-auto">
                <DashboardView />
                <PostsView />
                <DiariesView />
                <AlbumsView />
                <SettingsView />
            </div>
        </main>
    </div>

    </Layout>


<style is:global>
    .nav-item {
        @apply flex items-center gap-3 w-full px-4 py-3 text-left rounded-xl transition-all text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800;
    }
    .nav-item.active {
        @apply bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-bold;
    }
    .stat-card {
        @apply bg-white dark:bg-[#25262b] p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800;
    }
    .quick-btn {
        @apply px-6 py-4 rounded-xl font-bold transition active:scale-95;
    }
    .nav-item {
        @apply flex items-center gap-3 w-full px-4 py-3 text-left rounded-xl transition-all text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800;
    }
    .nav-item.active {
        @apply bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-bold;
    }
    .stat-card {
        @apply bg-white dark:bg-[#25262b] p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800;
    }
    .quick-btn {
        @apply px-6 py-4 rounded-xl font-bold transition active:scale-95 text-sm;
    }

    /* 修复报错：手动定义动画代替 tailwind-animate 插件 */
    .tab-content {
        animation: slideIn 0.3s ease-out forwards;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

    <script>
        // 第三步解耦：核心逻辑模块化
        import "../../scripts/admin-core.ts";
    </script>