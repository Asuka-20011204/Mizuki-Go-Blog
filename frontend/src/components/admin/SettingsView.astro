---
// src/components/admin/SettingsView.astro
import { Icon } from 'astro-icon/components';
---

<section id="settings-view" class="tab-content hidden space-y-5">
    <!-- 头部操作栏 -->
    <div class="flex flex-wrap justify-between items-center gap-4 sticky top-0 z-10 bg-[#f4f7f6] dark:bg-[#1a1b1e] pb-3">
        <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 flex items-center gap-2">
            <span class="w-2 h-8 bg-gradient-to-b from-blue-400 to-purple-500 rounded-full"></span>
             站点配置管理
        </h3>
        <div class="flex items-center gap-3">
            <span id="config-save-status" class="hidden text-sm text-green-500 bg-green-50 dark:bg-green-900/20 px-4 py-2 rounded-full"></span>
            <button id="save-config-btn" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl font-medium shadow-md transition-all active:scale-95 flex items-center gap-2">
                <Icon name="material-symbols:save-outline" class="text-lg" /> 保存配置
            </button>
        </div>
    </div>

    <!-- 单列配置卡片列表 -->
    <div class="space-y-4">

        <!-- 1. 基础信息（不可折叠，始终可见） -->
        <div class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800">
            <h4 class="text-md font-bold mb-4 flex items-center gap-2 text-gray-700 dark:text-gray-200">
                <Icon name="material-symbols:info-outline" /> 基础信息
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div><label class="text-xs font-medium text-gray-500">站点标题</label><input id="cfg-site-title" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium text-gray-500">副标题</label><input id="cfg-site-subtitle" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium text-gray-500">站点URL</label><input id="cfg-site-url" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium text-gray-500">起始日期</label><input type="date" id="cfg-site-start-date" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium text-gray-500">时区 (UTC±)</label><input type="number" id="cfg-timezone" min="-12" max="12" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium text-gray-500">语言</label><input id="cfg-lang" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
            </div>
            <div class="mt-4 flex flex-wrap items-center gap-6">
                <label class="flex items-center gap-2 text-sm"><span>主题色相 (0-360):</span><input type="number" id="cfg-theme-hue" min="0" max="360" class="w-20 p-1.5 rounded-lg border dark:bg-gray-800" /></label>
                <label class="flex items-center gap-2 text-sm"><input type="checkbox" id="cfg-theme-fixed" class="accent-blue-500" /> 固定主题色</label>
            </div>
        </div>

        <!-- 2. 页面开关（不可折叠） -->
        <div class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800">
            <h4 class="text-md font-bold mb-3 flex items-center gap-2"><Icon name="material-symbols:toggle-on-outline" /> 页面开关</h4>
            <div class="grid grid-cols-4 md:grid-cols-8 gap-3">
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-anime" class="accent-blue-500" /> 番剧</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-diary" class="accent-blue-500" /> 日记</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-friends" class="accent-blue-500" /> 友链</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-projects" class="accent-blue-500" /> 项目</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-skills" class="accent-blue-500" /> 技能</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-timeline" class="accent-blue-500" /> 时间线</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-albums" class="accent-blue-500" /> 相册</label>
                <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="cfg-page-devices" class="accent-blue-500" /> 设备</label>
            </div>
        </div>

        <!-- 个人资料（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:person-outline" /> 个人资料
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-3">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div><label class="text-xs font-medium">头像路径</label><input id="cfg-profile-avatar" class="w-full p-2 rounded border dark:bg-gray-800" placeholder="assets/images/avatar.webp" /></div>
                    <div><label class="text-xs font-medium">名称</label><input id="cfg-profile-name" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                    <div class="col-span-full"><label class="text-xs font-medium">个人简介</label><input id="cfg-profile-bio" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                </div>
                <div class="flex items-center gap-6">
                    <label class="flex items-center gap-2"><input type="checkbox" id="cfg-profile-typewriter-enable" class="accent-blue-500" /> 启用打字机效果</label>
                    <div><label class="text-xs font-medium">打字速度(ms)</label><input type="number" id="cfg-profile-typewriter-speed" class="w-24 p-2 rounded border dark:bg-gray-800" /></div>
                </div>
                <div>
                    <label class="text-xs font-medium">社交链接 (一行一个 JSON 对象，格式: &#123;"name":"...","icon":"...","url":"..."&#125;)</label>
                    <textarea id="cfg-profile-links" rows="4" class="w-full p-2 rounded border dark:bg-gray-800 font-mono text-xs"></textarea>
                    <p class="text-xs text-gray-400 mt-1">示例: &#123;"name":"GitHub","icon":"fa6-brands:github","url":"https://github.com/..."&#125;</p>
                </div>
            </div>
        </details>

        <!-- 公告配置（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:campaign-outline" /> 公告配置
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-3">
                <div class="flex items-center gap-4">
                    <label class="flex items-center gap-2"><input type="checkbox" id="cfg-announce-enable" class="accent-blue-500" /> 启用公告</label>
                </div>
                <div><label class="text-xs font-medium">标题</label><input id="cfg-announce-title" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">内容</label><textarea id="cfg-announce-content" rows="3" class="w-full p-2 rounded border dark:bg-gray-800"></textarea></div>
                <div class="flex items-center gap-4">
                    <label class="flex items-center gap-2"><input type="checkbox" id="cfg-announce-closable" class="accent-blue-500" /> 允许关闭</label>
                </div>
                <div class="border-t pt-3">
                    <label class="text-xs font-medium">链接设置</label>
                    <div class="flex items-center gap-4 mt-1">
                        <label class="flex items-center gap-2"><input type="checkbox" id="cfg-announce-link-enable" class="accent-blue-500" /> 启用链接</label>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-2">
                        <input id="cfg-announce-link-text" placeholder="链接文字" class="p-2 rounded border dark:bg-gray-800" />
                        <input id="cfg-announce-link-url" placeholder="链接 URL" class="p-2 rounded border dark:bg-gray-800" />
                        <label class="flex items-center gap-2"><input type="checkbox" id="cfg-announce-link-external" class="accent-blue-500" /> 外部链接</label>
                    </div>
                </div>
            </div>
        </details>

        <!-- 页脚配置（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:bottom-panel-close-outline" /> 页脚配置
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-3">
                <label class="flex items-center gap-2"><input type="checkbox" id="cfg-footer-enable" class="accent-blue-500" /> 启用自定义页脚 HTML</label>
                <div><label class="text-xs font-medium">自定义 HTML</label><textarea id="cfg-footer-html" rows="4" class="w-full p-2 rounded border dark:bg-gray-800 font-mono text-xs"></textarea></div>
                <p class="text-xs text-gray-400">例如备案号、版权信息等。</p>
            </div>
        </details>


        <!-- 3. 整体布局（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:wallpaper" /> 整体布局
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                <div><label class="text-xs font-medium">默认壁纸模式</label>
                    <select id="cfg-wallpaper-mode" class="w-full p-2 rounded-lg border dark:bg-gray-800">
                        <option value="banner">顶部横幅</option><option value="fullscreen">全屏壁纸</option><option value="none">无壁纸</option>
                    </select>
                </div>
                <div><label class="text-xs font-medium">切换按钮显示</label>
                    <select id="cfg-mode-switch-display" class="w-full p-2 rounded-lg border dark:bg-gray-800">
                        <option value="desktop">仅桌面端</option><option value="mobile">仅移动端</option><option value="both">所有设备</option><option value="off">不显示</option>
                    </select>
                </div>
                <div><label class="text-xs font-medium">文章列表布局</label>
                    <select id="cfg-postlist-default" class="w-full p-2 rounded-lg border dark:bg-gray-800">
                        <option value="list">列表</option><option value="grid">网格</option>
                    </select>
                </div>
                <div class="flex items-end pb-2"><label class="flex items-center gap-2"><input type="checkbox" id="cfg-postlist-switch" class="accent-blue-500" /> 允许用户切换布局</label></div>
            </div>
        </details>

        <!-- 4. 导航栏（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:menu-open" /> 导航栏
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                <div><label class="text-xs font-medium">标题文字</label><input id="cfg-navbar-title-text" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">标题图标</label><input id="cfg-navbar-title-icon" class="w-full p-2 rounded-lg border dark:bg-gray-800" placeholder="assets/home/home.png" /></div>
                <div><label class="text-xs font-medium">透明模式</label>
                    <select id="cfg-navbar-transparent" class="w-full p-2 rounded-lg border dark:bg-gray-800">
                        <option value="semi">半透明圆角</option><option value="full">完全透明</option><option value="semifull">动态透明</option>
                    </select>
                </div>
            </div>
        </details>

        <!-- 5. 横幅配置（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:image" /> 横幅配置
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-3">
                <div><label class="text-xs font-medium">桌面图片 (一行一个URL)</label><textarea id="cfg-banner-desktop" rows="3" class="w-full p-2 rounded-lg border dark:bg-gray-800 font-mono text-xs"></textarea></div>
                <div><label class="text-xs font-medium">移动图片</label><textarea id="cfg-banner-mobile" rows="3" class="w-full p-2 rounded-lg border dark:bg-gray-800 font-mono text-xs"></textarea></div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <div><label class="text-xs font-medium">位置</label>
                        <select id="cfg-banner-position" class="w-full p-2 rounded-lg border dark:bg-gray-800">
                            <option value="center">居中</option><option value="top">顶部</option><option value="bottom">底部</option>
                        </select>
                    </div>
                    <div><label class="text-xs font-medium">轮播间隔(秒)</label><input type="number" step="0.5" id="cfg-banner-carousel-interval" class="w-full p-2 rounded-lg border dark:bg-gray-800" /></div>
                    <div class="flex items-end gap-4 pb-1">
                        <label><input type="checkbox" id="cfg-banner-carousel-enable" class="accent-blue-500" /> 启用轮播</label>
                    </div>
                </div>
                <div class="flex flex-wrap gap-4">
                    <label><input type="checkbox" id="cfg-banner-waves-enable" class="accent-blue-500" /> 水波纹</label>
                    <label><input type="checkbox" id="cfg-banner-waves-perf" /> 性能模式</label>
                    <label><input type="checkbox" id="cfg-banner-waves-mobiledisable" /> 移动端禁用</label>
                </div>
                <div class="border-t pt-3">
                    <div class="flex items-center gap-4 mb-2"><label class="font-medium">主页文字</label><label><input type="checkbox" id="cfg-banner-homeText-enable" class="accent-blue-500" /> 启用</label></div>
                    <input id="cfg-banner-homeTitle" placeholder="主标题" class="w-full p-2 rounded-lg border dark:bg-gray-800 mb-2" />
                    <textarea id="cfg-banner-subtitles" rows="2" placeholder="副标题 (一行一句)" class="w-full p-2 rounded-lg border dark:bg-gray-800"></textarea>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mt-3">
                        <label class="flex items-center gap-1"><input type="checkbox" id="cfg-banner-typewriter-enable" /> 打字机</label>
                        <input type="number" id="cfg-banner-typewriter-speed" placeholder="速度(ms)" class="p-2 rounded border dark:bg-gray-800" />
                        <input type="number" id="cfg-banner-typewriter-delete" placeholder="删除速度" class="p-2 rounded border dark:bg-gray-800" />
                        <input type="number" id="cfg-banner-typewriter-pause" placeholder="暂停时间" class="p-2 rounded border dark:bg-gray-800" />
                    </div>
                </div>
            </div>
        </details>

        <!-- 6. 全屏壁纸（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:blur-on" /> 全屏壁纸
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-3">
                <textarea id="cfg-fullscreen-desktop" rows="2" placeholder="桌面图片 (一行一个URL)" class="w-full p-2 rounded-lg border dark:bg-gray-800"></textarea>
                <textarea id="cfg-fullscreen-mobile" rows="2" placeholder="移动图片" class="w-full p-2 rounded-lg border dark:bg-gray-800"></textarea>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <div><label class="text-xs font-medium">位置</label><select id="cfg-fullscreen-position" class="w-full p-2 rounded border dark:bg-gray-800"><option value="center">居中</option><option value="top">顶部</option><option value="bottom">底部</option></select></div>
                    <div><label class="text-xs font-medium">透明度</label><input type="number" step="0.1" id="cfg-fullscreen-opacity" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                    <div><label class="text-xs font-medium">模糊度(px)</label><input type="number" id="cfg-fullscreen-blur" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                    <div><label class="text-xs font-medium">层级</label><input type="number" id="cfg-fullscreen-zindex" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                    <div><label class="text-xs font-medium">轮播间隔(秒)</label><input type="number" id="cfg-fullscreen-carousel-interval" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                    <div class="flex items-end"><label><input type="checkbox" id="cfg-fullscreen-carousel-enable" class="accent-blue-500" /> 启用轮播</label></div>
                </div>
            </div>
        </details>

        <!-- 7. 字体配置（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:font-download-outline" /> 自定义字体
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-4">
                <div class="border-b pb-3">
                    <h5 class="font-semibold mb-2">英文字体 (ASCII)</h5>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <input id="cfg-font-ascii-family" placeholder="字体族名" class="p-2 rounded border dark:bg-gray-800" />
                        <input id="cfg-font-ascii-weight" placeholder="字重" class="p-2 rounded border dark:bg-gray-800" />
                        <input id="cfg-font-ascii-files" placeholder="字体文件 (逗号分隔)" class="p-2 rounded border dark:bg-gray-800 col-span-1 md:col-span-2" />
                    </div>
                    <label class="mt-2 inline-block"><input type="checkbox" id="cfg-font-compress-ascii" class="accent-blue-500" /> 启用子集压缩</label>
                </div>
                <div>
                    <h5 class="font-semibold mb-2">中日韩字体 (CJK)</h5>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <input id="cfg-font-cjk-family" placeholder="字体族名" class="p-2 rounded border dark:bg-gray-800" />
                        <input id="cfg-font-cjk-weight" placeholder="字重" class="p-2 rounded border dark:bg-gray-800" />
                        <input id="cfg-font-cjk-files" placeholder="字体文件 (逗号分隔)" class="p-2 rounded border dark:bg-gray-800 col-span-1 md:col-span-2" />
                    </div>
                    <label class="mt-2 inline-block"><input type="checkbox" id="cfg-font-compress-cjk" class="accent-blue-500" /> 启用子集压缩</label>
                </div>
            </div>
        </details>

        <!-- 8. 文章功能（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:article-outline" /> 文章功能
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 space-y-3">
                <div class="flex flex-wrap items-center gap-4">
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-toc-enable" class="accent-blue-500" /> 目录</label>
                    <input type="number" id="cfg-toc-depth" min="1" max="6" placeholder="深度" class="w-20 p-1.5 rounded border dark:bg-gray-800" />
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-toc-jpbadge" class="accent-blue-500" /> 日语假名标记</label>
                </div>
                <div class="flex flex-wrap items-center gap-4">
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-comment-enable" class="accent-blue-500" /> 评论 (Twikoo)</label>
                    <input id="cfg-twikoo-envid" placeholder="EnvId" class="p-1.5 rounded border dark:bg-gray-800 w-56" />
                    <input id="cfg-twikoo-lang" placeholder="语言" class="p-1.5 rounded border dark:bg-gray-800 w-20" />
                </div>
                <div class="flex flex-wrap items-center gap-4">
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-license-enable" class="accent-blue-500" /> 版权信息</label>
                    <input id="cfg-license-name" placeholder="协议名称" class="p-1.5 rounded border dark:bg-gray-800 w-40" />
                    <input id="cfg-license-url" placeholder="协议URL" class="p-1.5 rounded border dark:bg-gray-800 flex-1 min-w-[200px]" />
                </div>
                <div class="flex flex-wrap items-center gap-4">
                    <input id="cfg-code-theme" placeholder="代码块主题" class="p-1.5 rounded border dark:bg-gray-800 w-36" />
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-code-hideTransition" class="accent-blue-500" /> 主题切换时隐藏代码块</label>
                </div>
                <div class="flex flex-wrap gap-6">
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-show-lastmod" class="accent-blue-500" /> 显示最后编辑时间</label>
                    <label class="flex items-center gap-1"><input type="checkbox" id="cfg-generate-og" class="accent-blue-500" /> 生成 OG 图片</label>
                </div>
            </div>
        </details>

        <!-- 9. 音乐播放器（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:music-note" /> 音乐播放器
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                <label class="flex items-center gap-2"><input type="checkbox" id="cfg-music-enable" class="accent-blue-500" /> 启用</label>
                <div></div>
                <div><label class="text-xs font-medium">模式</label><select id="cfg-music-mode" class="w-full p-2 rounded border dark:bg-gray-800"><option value="meting">Meting</option><option value="local">本地</option></select></div>
                <div><label class="text-xs font-medium">歌单/歌曲 ID</label><input id="cfg-music-id" placeholder="ID" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div class="col-span-1 md:col-span-2"><label class="text-xs font-medium">Meting API</label><input id="cfg-meting-api" placeholder="API 地址" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">服务器</label><input id="cfg-music-server" placeholder="netease" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">类型</label><input id="cfg-music-type" placeholder="playlist" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
            </div>
        </details>

        <!-- 10. 樱花特效（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:park-outline" /> 樱花飘落特效
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-3">
                <label class="col-span-full"><input type="checkbox" id="cfg-sakura-enable" class="accent-blue-500" /> 启用</label>
                <input type="number" id="cfg-sakura-num" placeholder="数量" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-size-min" placeholder="最小尺寸" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-size-max" placeholder="最大尺寸" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-opacity-min" placeholder="最小透明度" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-opacity-max" placeholder="最大透明度" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-horiz-min" placeholder="水平速度最小" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-horiz-max" placeholder="水平速度最大" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-vert-min" placeholder="垂直速度最小" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.1" id="cfg-sakura-vert-max" placeholder="垂直速度最大" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.01" id="cfg-sakura-rotation" placeholder="旋转速度" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" step="0.01" id="cfg-sakura-fade" placeholder="消失速度" class="p-2 rounded border dark:bg-gray-800" />
                <input type="number" id="cfg-sakura-zindex" placeholder="层级" class="p-2 rounded border dark:bg-gray-800" />
            </div>
        </details>

        <!-- 11. Live2D 看板娘（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:person-4" /> Live2D 看板娘
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                <label class="col-span-full"><input type="checkbox" id="cfg-pio-enable" class="accent-blue-500" /> 启用</label>
                <div class="col-span-full"><label class="text-xs font-medium">模型路径 (逗号分隔)</label><input id="cfg-pio-models" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">位置</label><select id="cfg-pio-position" class="w-full p-2 rounded border dark:bg-gray-800"><option value="left">左侧</option><option value="right">右侧</option></select></div>
                <div><label class="text-xs font-medium">模式</label><select id="cfg-pio-mode" class="w-full p-2 rounded border dark:bg-gray-800"><option value="draggable">可拖拽</option><option value="fixed">固定</option></select></div>
                <div><label class="text-xs font-medium">宽度</label><input type="number" id="cfg-pio-width" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">高度</label><input type="number" id="cfg-pio-height" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div class="flex items-center"><label class="flex items-center gap-2"><input type="checkbox" id="cfg-pio-hidden-mobile" class="accent-blue-500" /> 移动端隐藏</label></div>
                <div></div>
                <div class="col-span-full"><label class="text-xs font-medium">欢迎语</label><input id="cfg-pio-welcome" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div class="col-span-full"><label class="text-xs font-medium">触摸提示 (一行一句)</label><textarea id="cfg-pio-touch" rows="2" class="w-full p-2 rounded border dark:bg-gray-800"></textarea></div>
                <div class="col-span-full"><label class="text-xs font-medium">首页提示</label><input id="cfg-pio-home" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div class="col-span-full"><label class="text-xs font-medium">换装提示 (一行一句)</label><textarea id="cfg-pio-skin" rows="2" class="w-full p-2 rounded border dark:bg-gray-800"></textarea></div>
                <div><label class="text-xs font-medium">关闭提示</label><input id="cfg-pio-close" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
                <div><label class="text-xs font-medium">关于链接</label><input id="cfg-pio-link" class="w-full p-2 rounded border dark:bg-gray-800" /></div>
            </div>
        </details>

        <!-- 12. 侧边栏布局（可折叠） -->
        <details class="bg-white dark:bg-[#25262b] rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800 group">
            <summary class="text-md font-bold flex items-center gap-2 cursor-pointer list-none marker:hidden">
                <Icon name="material-symbols:dehaze" /> 侧边栏布局
                <span class="ml-auto text-gray-400 group-open:hidden"><Icon name="material-symbols:expand-more" /></span>
                <span class="ml-auto text-gray-400 hidden group-open:inline"><Icon name="material-symbols:expand-less" /></span>
            </summary>
            <div class="mt-4">
                <div class="mb-4">
                    <label class="text-xs font-medium">侧边栏位置</label>
                    <select id="cfg-sidebar-position" class="p-2 rounded border dark:bg-gray-800 w-40">
                        <option value="unilateral">单侧</option><option value="both">双侧</option>
                    </select>
                </div>
                <div id="sidebar-components-list" class="space-y-2">
                    <!-- 由 admin-core.ts 动态渲染 -->
                </div>
                <p class="text-xs text-gray-400 mt-2">启用、排序、位置 (左侧/右侧)</p>
            </div>
        </details>
    </div>
</section>